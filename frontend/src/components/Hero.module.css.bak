.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--theme-hero-bg);
}

.canvas {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
}

.vignette {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 65% at 50% 50%, rgba(5,5,16,.2) 0%, rgba(2,2,10,.85) 100%),
    linear-gradient(to bottom, rgba(9,9,15,.45) 0%, transparent 28%, transparent 72%, rgba(9,9,15,.78) 100%);
}

.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 2rem;
  gap: 1.1rem;
  will-change: transform, opacity;
}

.chirecRow {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.04em;
}

.logoWrap {
  width: 120px; height: 120px;
  border-radius: 50%;
  border: 2px solid rgba(192,57,43,0.3);
  background: rgba(9,9,15,0.6);
  display: flex; align-items: center; justify-content: center;
  padding: 10px;
  box-shadow: 0 0 50px rgba(192,57,43,0.18), inset 0 0 20px rgba(192,57,43,0.05);
  animation: float 6s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-8px); }
}

.logoImg { width: 90px; height: 90px; object-fit: contain; border-radius: 6px; }

/* ── BADGE — premium pill with gradient border ── */
.badge {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 6px 20px;
  border-radius: 100px;
  font-family: var(--font-ui);
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.34em;
  text-transform: uppercase;
  color: #85DEFF;
  background:
    linear-gradient(rgba(5,8,14,0.88), rgba(5,8,14,0.88)) padding-box,
    linear-gradient(110deg, rgba(231,76,60,0.85), rgba(86,204,242,0.20) 40%, rgba(86,204,242,0.85)) border-box;
  border: 1px solid transparent;
  box-shadow:
    0 0 24px rgba(86,204,242,0.12),
    0 0 14px rgba(192,57,43,0.10),
    inset 0 1px 0 rgba(255,255,255,0.05);
  text-shadow: 0 0 16px rgba(86,204,242,0.45);
}

.badgeDot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: #e74c3c;
  box-shadow: 0 0 10px rgba(231,76,60,0.95), 0 0 20px rgba(231,76,60,0.5);
  animation: badgePulse 2.4s ease-in-out infinite;
}

@keyframes badgePulse {
  0%, 100% { opacity: 1;   transform: scale(1);    }
  50%       { opacity: 0.4; transform: scale(0.75); }
}

.title {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  font-family: var(--font-brand);
  line-height: 1;
}

.chirec {
  display: inline-block;
  font-size: clamp(3.8rem, 11vw, 7.5rem);
  font-weight: 900;
  color: var(--theme-text);
  letter-spacing: 0.07em;
  text-shadow: 0 0 80px rgba(192,57,43,0.3);
  will-change: transform;
}

.mun {
  font-size: clamp(0.85rem, 2vw, 1.3rem);
  font-weight: 300;
  color: var(--theme-text-65);
  letter-spacing: 0.38em;
  text-transform: uppercase;
}

.year {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 900;
  letter-spacing: 0.12em;
  background: linear-gradient(180deg, #e74c3c 0%, #c0392b 70%, #8e1f15 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
  filter: drop-shadow(0 0 28px rgba(192,57,43,0.55));
}

.slogan {
  font-family: var(--font-ui);
  font-size: clamp(0.9rem, 2vw, 1.25rem);
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--red-h);
  text-shadow: 0 0 30px rgba(192,57,43,0.45);
}

.location {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: var(--font-body);
  font-size: 0.78rem;
  color: var(--theme-text-45);
  letter-spacing: 0.05em;
}
.location svg { color: var(--red); flex-shrink: 0; }

.actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 0.4rem;
}

.btnPrimary {
  position: relative; overflow: hidden;
  display: inline-flex; align-items: center;
  padding: 0.9rem 2.4rem;
  background: linear-gradient(160deg, rgba(30,10,8,0.82) 0%, rgba(18,5,4,0.78) 100%);
  color: rgba(255,255,255,0.92);
  font-family: var(--font-ui); font-weight: 700; font-size: 0.82rem;
  letter-spacing: 0.08em; text-transform: uppercase; border-radius: 999px;
  border: 1px solid rgba(192,57,43,0.22);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.07), 0 2px 6px rgba(0,0,0,0.45);
  transition: background 0.32s ease, border-color 0.32s ease, box-shadow 0.32s ease;
}
.btnPrimary::after {
  content: ''; position: absolute; top: 0; left: 0;
  width: 45%; height: 100%;
  background: linear-gradient(105deg, transparent 20%, rgba(255,255,255,0.13) 50%, transparent 80%);
  transform: translateX(-160%) skewX(-18deg); transition: none; pointer-events: none;
}
.btnPrimary:hover { background: linear-gradient(160deg, rgba(45,14,10,0.90) 0%, rgba(28,8,6,0.86) 100%); border-color: rgba(231,76,60,0.50); box-shadow: inset 0 1px 0 rgba(255,255,255,0.09), 0 4px 16px rgba(0,0,0,0.5), 0 0 32px rgba(192,57,43,0.22); }
.btnPrimary:hover::after { transform: translateX(380%) skewX(-18deg); transition: transform 0.52s ease; }
.btnPrimary:active { box-shadow: inset 0 2px 5px rgba(0,0,0,0.3); transition-duration: 0.08s; }

.btnGhost {
  position: relative; overflow: hidden;
  display: inline-flex; align-items: center;
  padding: 0.9rem 2.4rem;
  background: rgba(8,18,24,0.72);
  color: rgba(86,204,242,0.88);
  font-family: var(--font-ui); font-weight: 700; font-size: 0.82rem;
  letter-spacing: 0.08em; text-transform: uppercase; border-radius: 999px;
  border: 1px solid rgba(86,204,242,0.16);
  box-shadow: inset 0 1px 0 rgba(86,204,242,0.06), 0 2px 6px rgba(0,0,0,0.4);
  transition: background 0.32s ease, border-color 0.32s ease, box-shadow 0.32s ease, color 0.28s ease;
}
.btnGhost::after {
  content: ''; position: absolute; top: 0; left: 0;
  width: 45%; height: 100%;
  background: linear-gradient(105deg, transparent 20%, rgba(86,204,242,0.12) 50%, transparent 80%);
  transform: translateX(-160%) skewX(-18deg); transition: none; pointer-events: none;
}
.btnGhost:hover { background: rgba(10,22,30,0.82); border-color: rgba(86,204,242,0.36); color: rgba(86,204,242,1); box-shadow: inset 0 1px 0 rgba(86,204,242,0.09), 0 4px 16px rgba(0,0,0,0.45), 0 0 30px rgba(86,204,242,0.14); }
.btnGhost:hover::after { transform: translateX(380%) skewX(-18deg); transition: transform 0.52s ease; }
.btnGhost:active { box-shadow: inset 0 2px 5px rgba(0,0,0,0.28); transition-duration: 0.08s; }

/* ── SCROLL HINT — mouse-track glider ── */
.scrollHint {
  position: absolute;
  bottom: 2.3rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}

.scrollLabel {
  font-family: var(--font-ui);
  font-size: 0.56rem;
  font-weight: 700;
  letter-spacing: 0.36em;
  text-transform: uppercase;
  color: rgba(244,244,239,0.40);
  animation: labelPulse 3s ease-in-out infinite;
}

@keyframes labelPulse {
  0%, 100% { opacity: 0.35; }
  50%       { opacity: 0.9; }
}

.scrollTrack {
  position: relative;
  width: 1px;
  height: 52px;
  background: linear-gradient(to bottom, rgba(192,57,43,0.45), rgba(192,57,43,0.05));
  overflow: hidden;
  border-radius: 1px;
}

.scrollGlider {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 16px;
  background: linear-gradient(to bottom, transparent, #e74c3c, transparent);
  box-shadow: 0 0 8px rgba(231,76,60,0.9);
  animation: glide 2.2s cubic-bezier(0.65, 0, 0.35, 1) infinite;
}

@keyframes glide {
  0%   { transform: translateY(-18px); opacity: 0; }
  30%  { opacity: 1; }
  100% { transform: translateY(56px);  opacity: 0; }
}
